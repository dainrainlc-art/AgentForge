{
  "name": "agentforge-frontend",
  "version": "1.0.0",
  "description": "AgentForge 前端 - React + TypeScript + Tailwind CSS",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
