# AgentForge 环境配置模板
# 复制此文件为 .env 并填写实际值
# 基于《AgentForge 个人助理系统架构规划方案》

# ===========================================
# 百度千帆 Coding Plan Pro 配置 (必需)
# ===========================================
QIANFAN_API_KEY=your_qianfan_api_key_here
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2/coding
QIANFAN_DEFAULT_MODEL=glm-5

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentforge
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=your_secure_postgres_password

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# JWT认证配置
# ===========================================
JWT_SECRET_KEY=your_jwt_secret_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
DEBUG_MODE=false
TZ=Asia/Shanghai

# ===========================================
# n8n工作流引擎配置
# ===========================================
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password
N8N_WEBHOOK_URL=http://localhost:5678/webhook/

# ===========================================
# Qdrant向量数据库配置
# ===========================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ===========================================
# GitHub配置 (可选)
# ===========================================
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_username
GITHUB_REPO_NAME=agentforge

# ===========================================
# Notion配置 (可选)
# ===========================================
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id

# ===========================================
# 社交媒体API配置 (可选)
# ===========================================
# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ===========================================
# Fiverr配置 (可选)
# ===========================================
FIVERR_API_KEY=your_fiverr_api_key

# ===========================================
# Obsidian配置
# ===========================================
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ===========================================
# 安全配置
# ===========================================
SECRET_KEY=your_secret_key_for_encryption
ENCRYPTION_KEY=your_aes_256_encryption_key

# ===========================================
# 外部访问配置 (可选)
# ===========================================
# PUBLIC_DOMAIN=your-domain.com
# WEBHOOK_URL=https://your-domain.com/webhook/
