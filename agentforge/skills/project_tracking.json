{
  "name": "项目进度跟踪",
  "version": "1.0.0",
  "description": "跟踪项目进度并生成报告",
  "trigger": {
    "type": "timer",
    "cron": "0 17 * * 5"
  },
  "actions": [
    {
      "type": "query_data",
      "params": {
        "type": "projects",
        "params": {
          "status": "active"
        }
      }
    },
    {
      "type": "ai_generate",
      "params": {
        "model": "glm-5",
        "prompt": "根据以下项目数据生成进度报告：{{data}}"
      },
      "timeout": 60
    },
    {
      "type": "send_message",
      "params": {
        "to": "user",
        "subject": "项目进度周报",
        "content": "{{ai_result}}"
      }
    }
  ],
  "enabled": true,
  "tags": ["project", "tracking"],
  "author": "System"
}
