{
  "name": "多平台内容同步",
  "version": "1.0.0",
  "description": "将内容同步到多个社交媒体平台",
  "trigger": {
    "type": "event",
    "event_type": "content_ready",
    "conditions": []
  },
  "actions": [
    {
      "type": "http_request",
      "params": {
        "method": "POST",
        "url": "https://api.twitter.com/2/tweets",
        "headers": {
          "Authorization": "Bearer {{twitter_token}}"
        },
        "body": {
          "text": "{{content}}"
        }
      }
    },
    {
      "type": "http_request",
      "params": {
        "method": "POST",
        "url": "https://api.linkedin.com/v2/shares",
        "headers": {
          "Authorization": "Bearer {{linkedin_token}}"
        },
        "body": {
          "text": {
            "text": "{{content}}"
          }
        }
      }
    },
    {
      "type": "http_request",
      "params": {
        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/{{facebook_page_id}}/feed",
        "headers": {
          "Authorization": "Bearer {{facebook_token}}"
        },
        "body": {
          "message": "{{content}}"
        }
      }
    }
  ],
  "enabled": true,
  "tags": ["social-media", "sync"],
  "author": "System"
}
