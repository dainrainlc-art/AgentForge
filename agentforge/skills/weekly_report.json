{
  "name": "周报生成",
  "version": "1.0.0",
  "description": "自动生成工作周报",
  "trigger": {
    "type": "timer",
    "cron": "0 17 * * 5"
  },
  "actions": [
    {
      "type": "query_data",
      "params": {
        "type": "tasks",
        "params": {
          "week": "{{current_week}}",
          "status": "completed"
        }
      }
    },
    {
      "type": "ai_generate",
      "params": {
        "model": "glm-5",
        "prompt": "根据以下完成的任务生成工作周报：{{data}}"
      },
      "timeout": 60
    },
    {
      "type": "send_message",
      "params": {
        "to": "manager",
        "subject": "工作周报 - 第{{current_week}}周",
        "content": "{{ai_result}}"
      }
    }
  ],
  "enabled": true,
  "tags": ["report", "weekly"],
  "author": "System"
}
