{
  "name": "差评预警处理",
  "version": "1.0.0",
  "description": "监控并处理差评预警",
  "trigger": {
    "type": "event",
    "event_type": "negative_feedback",
    "conditions": []
  },
  "actions": [
    {
      "type": "ai_generate",
      "params": {
        "model": "glm-5",
        "prompt": "客户表达了不满，生成安抚和解决方案：{{feedback_content}}"
      },
      "timeout": 60
    },
    {
      "type": "send_message",
      "params": {
        "to": "{{customer_id}}",
        "content": "{{ai_result}}"
      }
    },
    {
      "type": "create_task",
      "params": {
        "title": "处理差评预警 #{{order_id}}",
        "description": "客户反馈：{{feedback_content}}",
        "priority": "urgent"
      }
    }
  ],
  "enabled": true,
  "tags": ["feedback", "urgent"],
  "author": "System"
}
